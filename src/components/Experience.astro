---
import { useTranslations } from '../i18n/utils';
import { experienceList } from '../data/experience';

interface Props {
  locale: 'en' | 'id';
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="experience" class="py-20 px-6 md:px-12 bg-white text-black transition-colors duration-200">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-mono text-xs font-bold tracking-widest text-neutral-400 uppercase mb-12">
      {t('nav.experience').toUpperCase()}
    </h2>

    <div class="relative">
      <div class="hidden md:block absolute left-[5px] top-2 bottom-2 w-px bg-neutral-200"></div>

      <div class="space-y-12">
        {experienceList.map((exp) => (
          <div class="relative md:pl-10">
            <div class="hidden md:block absolute left-0 top-2 w-[11px] h-[11px] rounded-full border-2 border-neutral-300 bg-white z-10"></div>

            <div class="border border-neutral-200 rounded p-6 md:p-8 bg-neutral-50/20 hover:border-black hover:shadow-sm transition-all duration-200">
              {exp.projects ? (
                <div>
                  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-2">
                    <h3 class="text-lg font-bold tracking-tight text-black">
                      {exp.company}
                    </h3>
                    <span class="font-mono text-[11px] font-bold text-neutral-400 tracking-wider whitespace-nowrap">
                      {exp.date}
                    </span>
                  </div>
                  {exp.projects.map((project, i) => (
                    <div>
                      {i > 0 && <hr class="border-neutral-200 my-6" />}
                      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-3">
                        <div>
                          <h4 class="text-base font-bold tracking-tight text-black">
                            {project.title}
                          </h4>
                          <p class="font-mono text-xs text-neutral-500 mt-0.5">
                            {project.role}
                          </p>
                        </div>
                        <span class="font-mono text-[11px] font-bold text-neutral-400 tracking-wider whitespace-nowrap">
                          {project.date}
                        </span>
                      </div>
                      <p class="text-sm text-neutral-600 leading-relaxed mb-4">
                        {project.description}
                      </p>
                      <ul class="space-y-1.5 mb-5">
                        {project.responsibilities.map((item) => (
                          <li class="flex items-start gap-2 text-sm text-neutral-600 leading-relaxed">
                            <span class="mt-2 w-1 h-1 rounded-full bg-neutral-300 shrink-0"></span>
                            {item}
                          </li>
                        ))}
                      </ul>
                      <div class="flex flex-wrap gap-1.5">
                        {project.tags.map((tag) => (
                          <span class="font-mono text-[10px] font-bold text-neutral-500 bg-neutral-100/80 px-2 py-0.5 rounded border border-neutral-200/50">
                            {tag}
                          </span>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              ) : (
                <div>
                  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
                    <div>
                      <h3 class="text-lg font-bold tracking-tight text-black">
                        {exp.role}
                      </h3>
                      <p class="text-sm text-neutral-500 font-medium">
                        {exp.company}
                      </p>
                    </div>
                    <span class="font-mono text-[11px] font-bold text-neutral-400 tracking-wider whitespace-nowrap">
                      {exp.date}
                    </span>
                  </div>
                  <p class="text-sm text-neutral-600 leading-relaxed mb-4">
                    {exp.description}
                  </p>
                  <ul class="space-y-1.5 mb-5">
                    {exp.responsibilities.map((item) => (
                      <li class="flex items-start gap-2 text-sm text-neutral-600 leading-relaxed">
                        <span class="mt-2 w-1 h-1 rounded-full bg-neutral-300 shrink-0"></span>
                        {item}
                      </li>
                    ))}
                  </ul>
                  <div class="flex flex-wrap gap-1.5 pt-4 border-t border-neutral-200">
                    {exp.tags.map((tag) => (
                      <span class="font-mono text-[10px] font-bold text-neutral-500 bg-neutral-100/80 px-2 py-0.5 rounded border border-neutral-200/50">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
