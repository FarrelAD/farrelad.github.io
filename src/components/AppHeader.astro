---
import Icon from './Icon.astro';
import { useTranslations } from '../i18n/utils';

interface Props {
  locale: 'en' | 'id';
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const prefix = locale === 'en' ? '' : '/id';
const homeUrl = prefix || '/';
const skillsUrl = `${prefix}/#skills`;
const projectsUrl = `${prefix}/#projects`;
const contactUrl = `${prefix}/#contact`;
const blogUrl = `${prefix}/blog`;

const profiles = [
  {
    name: 'GitHub',
    url: 'https://github.com/FarrelAD',
    icon: 'mdi:github'
  },
  {
    name: 'Hugging Face',
    url: 'https://huggingface.co/FarrelAD',
    icon: 'simple-icons:huggingface'
  },
  {
    name: 'Kaggle',
    url: 'https://kaggle.com/farrelad',
    icon: 'simple-icons:kaggle'
  }
];
---

<header class="fixed top-0 left-0 right-0 bg-white/80 backdrop-blur-md z-50 border-b border-neutral-200/80 transition-colors duration-200">
  <nav class="max-w-6xl mx-auto px-6 md:px-12 py-5">
    <div class="flex items-center justify-between">
      
      <!-- Branding Logo -->
      <a href={homeUrl} class="font-mono font-bold text-sm tracking-widest text-black hover:opacity-75 transition-opacity">
        FARREL AD
      </a>

      <!-- Desktop Navigation -->
      <ul class="hidden md:flex items-center gap-10">
        <li>
          <a href={homeUrl} class="text-sm font-mono text-neutral-400 hover:text-black transition-colors">
            {t('nav.home').toUpperCase()}
          </a>
        </li>
        <li>
          <a href={skillsUrl} class="text-sm font-mono text-neutral-400 hover:text-black transition-colors">
            {t('nav.about').toUpperCase()}
          </a>
        </li>
        <li>
          <a href={projectsUrl} class="text-sm font-mono text-neutral-400 hover:text-black transition-colors">
            {t('nav.projects').toUpperCase()}
          </a>
        </li>
        <li>
          <a href={blogUrl} class="text-sm font-mono text-neutral-400 hover:text-black transition-colors">
            {t('nav.blog').toUpperCase()}
          </a>
        </li>
        <li>
          <a href={contactUrl} class="text-sm font-mono text-neutral-400 hover:text-black transition-colors">
            {t('nav.contact').toUpperCase()}
          </a>
        </li>
      </ul>

      <!-- Desktop Right Side Controls -->
      <div class="hidden md:flex items-center gap-5">
        <!-- Projects Dropdown -->
        <div class="relative" id="dropdown-container">
          <button 
            id="dropdown-btn"
            class="font-mono text-xs text-neutral-700 hover:text-black border border-neutral-300 hover:border-black px-3.5 py-1.5 rounded flex items-center gap-1.5 transition-all duration-200 cursor-pointer focus:outline-none"
          >
            {t('nav.projects').toUpperCase()}
            <svg 
              id="dropdown-arrow"
              class="w-3 h-3 transition-transform duration-200" 
              fill="none" 
              stroke="currentColor" 
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Dropdown List -->
          <div 
            id="dropdown-menu"
            class="hidden absolute right-0 mt-2 w-48 bg-white border border-neutral-200 rounded shadow-md overflow-hidden"
          >
            {profiles.map(profile => (
              <a 
                href={profile.url} 
                target="_blank" 
                rel="noopener noreferrer"
                class="group flex items-center justify-between px-4 py-2.5 text-xs font-mono text-neutral-600 hover:bg-neutral-50 hover:text-black transition-all duration-150"
              >
                <div class="flex items-center gap-2">
                  <Icon name={profile.icon} class="w-4 h-4 transition-transform duration-200 group-hover:scale-110" />
                  <span>{profile.name}</span>
                </div>
                <svg 
                  class="w-3.5 h-3.5 opacity-0 group-hover:opacity-100 transition-all duration-150 transform -translate-x-1 group-hover:translate-x-0" 
                  fill="none" 
                  stroke="currentColor" 
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            ))}
          </div>
        </div>

        <!-- Language Toggle -->
        <a 
          href={locale === 'en' ? '/id' : '/'}
          class="font-mono text-xs font-bold text-neutral-700 hover:text-black border border-neutral-300 hover:border-black px-3.5 py-1.5 rounded transition-all duration-200 text-center"
        >
          {locale === 'en' ? 'ID' : 'EN'}
        </a>
      </div>

      <!-- Mobile Controls Right Side -->
      <div class="flex md:hidden items-center gap-3">
        <a 
          href={locale === 'en' ? '/id' : '/'}
          class="font-mono text-xs font-bold text-neutral-700 hover:text-black border border-neutral-300 hover:border-black px-2.5 py-1 rounded transition-colors"
        >
          {locale === 'en' ? 'ID' : 'EN'}
        </a>
        
        <!-- Mobile Menu Toggle Button -->
        <button 
          id="mobile-menu-btn"
          class="p-1.5 text-neutral-700 hover:text-black focus:outline-none border border-transparent hover:border-neutral-200 rounded"
          aria-label="Toggle Menu"
        >
          <svg id="menu-icon-burger" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

    </div>

    <!-- Mobile Menu Overlay -->
    <div 
      id="mobile-menu" 
      class="hidden md:hidden mt-4 pb-4 border-t border-neutral-100 pt-4"
    >
      <ul class="space-y-3.5">
        <li>
          <a 
            href={homeUrl} 
            class="mobile-nav-link block font-mono text-sm text-neutral-500 hover:text-black"
          >
            {t('nav.home').toUpperCase()}
          </a>
        </li>
        <li>
          <a 
            href={skillsUrl} 
            class="mobile-nav-link block font-mono text-sm text-neutral-500 hover:text-black"
          >
            {t('nav.about').toUpperCase()}
          </a>
        </li>
        <li>
          <a 
            href={projectsUrl} 
            class="mobile-nav-link block font-mono text-sm text-neutral-500 hover:text-black"
          >
            {t('nav.projects').toUpperCase()}
          </a>
        </li>
        <li>
          <a 
            href={blogUrl} 
            class="mobile-nav-link block font-mono text-sm text-neutral-500 hover:text-black"
          >
            {t('nav.blog').toUpperCase()}
          </a>
        </li>
        <li>
          <a 
            href={contactUrl} 
            class="mobile-nav-link block font-mono text-sm text-neutral-500 hover:text-black"
          >
            {t('nav.contact').toUpperCase()}
          </a>
        </li>
      </ul>

      <!-- Mobile Profiles Section -->
      <div class="mt-6 pt-4 border-t border-neutral-100">
        <h3 class="font-mono text-xxs font-semibold text-neutral-400 uppercase tracking-widest mb-3">
          {t('nav.projects').toUpperCase()}
        </h3>
        <ul class="space-y-3">
          {profiles.map(profile => (
            <li>
              <a 
                href={profile.url} 
                target="_blank" 
                rel="noopener noreferrer"
                class="group flex items-center justify-between font-mono text-xs text-neutral-600 hover:text-black transition-colors"
              >
                <div class="flex items-center gap-2.5">
                  <Icon name={profile.icon} class="w-4 h-4 text-neutral-400 group-hover:text-black transition-colors" />
                  <span>{profile.name}</span>
                </div>
                <svg 
                  class="w-3.5 h-3.5 text-neutral-400 group-hover:text-black transition-colors" 
                  fill="none" 
                  stroke="currentColor" 
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile Menu Toggle logic
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const burgerIcon = document.getElementById('menu-icon-burger');
  const closeIcon = document.getElementById('menu-icon-close');
  const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

  function toggleMobileMenu() {
    mobileMenu?.classList.toggle('hidden');
    burgerIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  }

  mobileMenuBtn?.addEventListener('click', toggleMobileMenu);

  mobileNavLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      burgerIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    });
  });

  // Desktop Projects Dropdown Toggle
  const dropdownBtn = document.getElementById('dropdown-btn');
  const dropdownMenu = document.getElementById('dropdown-menu');
  const dropdownArrow = document.getElementById('dropdown-arrow');

  dropdownBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    dropdownMenu?.classList.toggle('hidden');
    dropdownArrow?.classList.toggle('rotate-180');
  });

  // Close dropdown when clicking outside
  document.addEventListener('click', (e) => {
    const target = e.target as Node;
    if (dropdownMenu && !dropdownMenu.contains(target) && dropdownBtn && !dropdownBtn.contains(target)) {
      dropdownMenu.classList.add('hidden');
      dropdownArrow?.classList.remove('rotate-180');
    }
  });
</script>
